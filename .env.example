# Required
SEARCH_URL=https://briansjobsearch.com/

# Runtime
RUN_MODE=all_companies
HEADLESS=true
POLL_MINUTES=15
LOOKBACK_HOURS=24
INCLUDE_UNPARSEABLE=true
USE_BRIANS_RESULTS_PARSER=true
ROLE_QUERY=Software Engineer
TIME_WINDOW=24hours
TIME_WINDOWS=1hour,4hours,8hours,12hours,24hours
GLOBAL_BOARD_SOURCES=Greenhouse,Lever,Ashby,Workday,SmartRecruiters,iCIMS,Dover,Oracle Cloud
REMOTE_ONLY=true
DB_PATH=/data/jobs.db
NAV_TIMEOUT_MS=60000
WAIT_FOR_SELECTOR=body
WAIT_AFTER_LOAD_MS=2000
LOG_NEW_PREVIEW_COUNT=3
EXPORT_CSV=true
EXPORT_CSV_PATH=/data/jobs_sheet.csv
EXPORT_LOOKBACK_HOURS=24
SHEET_ONLY_REAL_URLS=true
SHEET_POSTED_WINDOWS=
EXPORT_GOOGLE_SHEETS=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Jobs
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/data/google-service-account.json

# Source controls (comma-separated source names exactly as Brian shows, e.g. Ashby, Greenhouse, Lever)
SOURCE_INCLUDE=Ashby,Greenhouse,Lever,Workday,SmartRecruiters,iCIMS,Dover,Oracle Cloud
SOURCE_EXCLUDE=
USE_PROVIDER_BOARD_SCRAPERS=true
GREENHOUSE_BOARD_URLS=https://job-boards.greenhouse.io/your-company
LEVER_BOARD_URLS=https://jobs.lever.co/your-company
ASHBY_BOARD_URLS=https://jobs.ashbyhq.com/your-company

# Deep fetch controls: resolve Brian source links into real job posting URLs
DEEP_FETCH_RESULTS=true
MAX_RESULTS_PER_SOURCE=10
DEEP_FETCH_TIMEOUT_SEC=25
KEEP_SOURCE_LINK_IF_EMPTY=false
DEEP_FETCH_USER_AGENT=
DEBUG_DEEP_FETCH=true
DEEP_FETCH_WITH_PLAYWRIGHT=true
DEEP_FETCH_NAV_TIMEOUT_MS=45000
DEEP_FETCH_WAIT_AFTER_MS=1500
DEEP_FETCH_PROVIDER_ORDER=serper,serpapi,html
SERPER_API_KEY=
SERPAPI_API_KEY=

# Optional selector tuning (inspect site DOM and adjust these)
JOB_CARD_SELECTOR=article, li, div.job-card, div[data-job-id]
TITLE_SELECTOR=h2, h3, a
COMPANY_SELECTOR=.company, [data-testid*='company']
LOCATION_SELECTOR=.location, [data-testid*='location']
POSTED_SELECTOR=time, .posted, .date
LINK_SELECTOR=a[href]

# Debugging / selector calibration
DEBUG_SAVE_HTML=true
DEBUG_HTML_PATH=/data/last_page.html
DEBUG_LOG_SELECTORS=true

# Optional alerts
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional browser identity
USER_AGENT=
